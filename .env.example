# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/bichri_optique"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-nextauth-generer-avec-openssl"

# Upload d'images (optionnel - Cloudinary ou local)
UPLOAD_DIR="./public/uploads"

# Email (optionnel pour les notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="votre-mot-de-passe-app"

# URL du site
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Bichri Optique"
